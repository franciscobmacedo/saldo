{
  "name": "saldo",
  "version": "1.2.0",
  "description": "Portuguese salary calculator library",
  "author": "Francisco Macedo <me@fmacedo.com> (https://fmacedo.com)",
  "license": "ISC",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "vitest",
    "build": "tsc && tsc-alias",
    "dev": "tsx src/index.ts",
    "saldo:docs": "pnpm build && cd docs && pnpm install && pnpm dev",
    "compare:dependent": "tsx scripts/dependent-worker/index.ts",
    "compare:independent": "tsx scripts/independent-worker/index.ts",
    "update:manifest": "tsx scripts/update-manifest-2025.ts",
    "convert": "tsx scripts/excel-retention-table-to-json.ts",
    "isim": "tsx scripts/log-simulator-results.ts"
  },
  "keywords": [
    "portugal",
    "salary",
    "tax",
    "calculator"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/franciscobmacedo/saldo.git"
  },
  "packageManager": "pnpm@10.10.0",
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^22.15.17",
    "cli-progress": "^3.12.0",
    "playwright": "^1.55.0",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.3",
    "xlsx": "^0.18.5"
  }
}
